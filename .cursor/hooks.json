{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "matcher": "",
        "command": "node .cursor/hooks/cursor-skill-eval.js"
      }
    ],
    "preToolUse": [
      {
        "matcher": "Shell|Write|CreateFile|EditFile",
        "command": "node .cursor/hooks/cursor-pre-tool-use.js"
      }
    ],
    "stop": [
      {
        "matcher": "",
        "command": "node .cursor/hooks/stop.js"
      }
    ]
  }
}
